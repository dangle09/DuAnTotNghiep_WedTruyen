
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_LayoutLogin_Register.cshtml";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>

<body>

    <div class="auth-page">
        <div class="auth-bg"></div>

        <div class="auth-card">

            <!-- Logo -->
            <div class="auth-logo">
                <img src="~/images/logo1_Wed.png" alt="TeenNovel" />
            </div>

            <h1 class="auth-title">Tạo tài khoản</h1>

            <!-- Thông báo lỗi từ server -->
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="auth-alert auth-alert--error" id="serverError">
                    <i class="auth-icon-error">✕</i>
                    @ViewBag.Error
                </div>
            }

            <!-- Form -->
            <form id="registerForm" asp-controller="Login_Register" asp-action="Register" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="auth-field" id="fieldUsername">
                    <label for="regUsername">Tên đăng nhập</label>
                    <input type="text"
                           id="regUsername"
                           name="Tendangnhap"
                           placeholder="teennovel_user"
                           autocomplete="username"
                           value="@ViewBag.Tendangnhap" />
                    <span class="auth-error-msg" id="usernameError"></span>
                </div>

                <div class="auth-field" id="fieldEmail">
                    <label for="regEmail">Email</label>
                    <input type="email"
                           id="regEmail"
                           name="Email"
                           placeholder="email@example.com"
                           autocomplete="email"
                           value="@ViewBag.Email" />
                    <span class="auth-error-msg" id="emailError"></span>
                </div>

                <div class="auth-field" id="fieldPassword" style="margin-bottom:18px">
                    <label for="regPassword">Mật khẩu</label>
                    <div class="auth-input-wrap">
                        <input type="password"
                               id="regPassword"
                               name="Matkhau"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                        <button type="button" class="auth-eye" id="toggleRegPassword" aria-label="Hiện/ẩn mật khẩu">
                            <span id="eyeIconReg">👁</span>
                        </button>
                    </div>
                    <span class="auth-error-msg" id="passwordError"></span>
                </div>

                <button type="submit" class="auth-btn-main" id="registerBtn">
                    Đăng ký
                </button>
            </form>

            <div class="auth-divider"><span>hoặc</span></div>

            <!-- Google -->
            <a href="/auth/google" class="auth-btn-google">
                <svg class="auth-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                Đăng ký bằng Google
            </a>

            <p class="auth-switch">
                Đã có tài khoản?
                <a asp-controller="Login_Register" asp-action="Login">Đăng nhập</a>
            </p>

        </div>
    </div>

    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script>
            initRegisterForm();
    </script>
</body>
</html>
