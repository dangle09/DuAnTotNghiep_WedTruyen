@{
    Layout = "~/Views/Shared/_LayoutQuanLy.cshtml";
    ViewData["Title"]      = "Thêm chương";
    ViewData["ActivePage"] = "Chuong";
    var truyen = ViewBag.Truyen as TeenNovel_Wed.Models.Truyen;
}

@section Styles {
    <link rel="stylesheet" href="~/css/quan-ly-chuong.css" asp-append-version="true" />
}

@section TopbarAction {
    <a asp-action="ChiTietChuong" asp-route-id="@truyen?.Matruyen" class="ad-topbar-btn ad-topbar-btn--outline">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="qc-form-wrap">

    <!-- Info truyện đang thêm chương -->
    <div class="qc-form-truyen-info">
        @if (!string.IsNullOrEmpty(truyen?.AnhBia))
        {
            <img src="@truyen.AnhBia" alt="" />
        }
        else
        {
            <div class="qc-form-cover-placeholder"><i class="bi bi-book"></i></div>
        }
        <div>
            <div class="qc-form-truyen-label">Đang thêm chương cho truyện</div>
            <div class="qc-form-truyen-name">@truyen?.Tentruyen</div>
        </div>
    </div>

    <form asp-action="ThemChuong" method="post" id="chuongForm" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="matruyen" value="@truyen?.Matruyen" />

        <div class="ad-card">
            <div class="ad-card-head"><span class="ad-card-title">Thông tin chương</span></div>
            <div class="ad-card-body">

                <div class="qc-field-row">
                    <div class="qc-field">
                        <label>Tên chương <span class="qc-required">*</span></label>
                        <input type="text" name="tenchuong" id="tenchuong"
                               placeholder="VD: Chương 1: Khởi đầu..." maxlength="200" />
                        <span class="qc-err" id="err-tenchuong"></span>
                    </div>
                    <div class="qc-field" style="max-width:140px">
                        <label>Thứ tự <span class="qc-required">*</span></label>
                        <input type="number" name="thutu" id="thutu" min="1" value="@ViewBag.ThuTuDeXuat" />
                        <span class="qc-err" id="err-thutu"></span>
                    </div>
                </div>

                <div class="qc-field" style="max-width:200px">
                    <label>Giá xu</label>
                    <input type="number" name="giaxu" id="giaxu" min="0" value="0" />
                    <span class="qc-field-hint">0 = miễn phí</span>
                </div>

                <div class="qc-field">
                    <label>Nội dung chương <span class="qc-required">*</span></label>
                    <textarea name="noidung" id="noidung" rows="16"
                              placeholder="Dán hoặc nhập nội dung chương truyện..."></textarea>
                    <span class="qc-err" id="err-noidung"></span>
                    <span class="qc-field-hint" id="wordCount">0 từ</span>
                </div>

            </div>
        </div>

        <div class="qc-form-actions">
            <a asp-action="ChiTietChuong" asp-route-id="@truyen?.Matruyen" class="ad-topbar-btn ad-topbar-btn--outline">Huỷ</a>
            <button type="submit" class="ad-topbar-btn ad-topbar-btn--primary" id="submitBtn">
                <i class="bi bi-plus-lg"></i> Thêm chương
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/quan-ly-chuong.js" asp-append-version="true"></script>
    <script>initChuongForm();</script>
}
