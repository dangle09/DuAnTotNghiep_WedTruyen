@model IEnumerable<TeenNovel_Wed.Models.Truyen>


@{
    ViewData["Title"] = "Mới cập nhật";
    Layout = "~/Views/Shared/_LayoutDocGia.cshtml";

    ViewData["ActivePage"] = "MoiCapNhat";
}



<link rel="stylesheet"
      href="~/css/trang-chu.css"
      asp-append-version="true" />




<div class="tc-section container-fluid">


    <div class="tc-section-head">


        <h2 class="tc-section-title">

            <i class="bi bi-clock-history"></i>

            Truyện mới cập nhật trong 30 ngày

        </h2>


    </div>





    <div class="tc-cards-grid">

        @foreach (var t in Model)
        {

            <a asp-controller="DocGia"
                   asp-action="ChiTiet"
                   asp-route-id="@t.Matruyen"
                   class="tc-card">

                <div class="tc-cover">

                    @if (!string.IsNullOrEmpty(t.AnhBia))
                    {

                        <img src="@t.AnhBia"
                             alt="@t.Tentruyen" />

                    }
                    else
                    {

                        <div class="tc-cover-placeholder">

                            <i class="bi bi-book"></i>

                        </div>

                    }

                    <span class="tc-badge
                        @(t.Trangthai == "hoanthanh"
                                                  ? "tc-badge--blue"
                                                  :
                                                  t.Trangthai == "tamngung"
                                                  ? "tc-badge--amber"
                                                  :
                                                  "tc-badge--green")">


                        @(t.Trangthai == "hoanthanh"
                        ? "Hoàn thành"
                        :
                        t.Trangthai == "tamngung"
                        ? "Tạm ngưng"
                        :
                        "Đang ra")


                    </span>
                </div>


                <div class="tc-card-info">
                    <div class="tc-card-title">

                        @t.Tentruyen

                    </div>

                    <div class="tc-card-author">

                        @(t.MaTacGiaNavigation?.TenTacGia ?? "Đang cập nhật")

                    </div>

                    <div class="tc-card-meta">

                        <span>
                            <i class="bi bi-eye"></i>
                            @t.LuotDoc.ToString("N0")
                        </span>


                        <span>
                            <i class="bi bi-heart"></i>
                            @t.LuotThich.ToString("N0")
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>

    @if (!Model.Any())
    {

        <div class="tc-empty">

            Không có truyện mới trong 30 ngày gần đây

        </div>

    }



</div>
